			]
		},
		{
			"name": "Mock / System",
			"item": [
				{
					"name": "Trigger Mock Verify (Direct)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"documentKey\": \"{{document_key}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/mock/verify",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"mock",
								"verify"
							]
						},
						"description": "Directly calls the mock verification service. Useful for testing the mock logic without the full queue flow."
					},
					"response": [
						{
							"name": "Random Mock Result",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"status\": \"VERIFIED\",\n    \"confidence\": 0.85,\n    \"message\": \"Document integrity and data verified successfully.\"\n}"
						}
					]
				},
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								""
							]
						}
					},
					"response": []
