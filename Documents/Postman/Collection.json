						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/admin/verifications/{{record_id}}/history",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"verifications",
								"{{record_id}}",
								"history"
							]
						}
					},
					"response": []
				},
				{
					"name": "Get Document Link",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/admin/verifications/{{record_id}}/document",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"verifications",
								"{{record_id}}",
								"document"
							]
						}
					},
					"response": []
				},
				{
					"name": "Claim Record (Lock)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/admin/verifications/{{record_id}}/claim",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"verifications",
								"{{record_id}}",
								"claim"
							]
						}
					},
					"response": []
				},
				{
					"name": "Submit Decision",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{auth_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"decision\": \"approved\",\n    \"reason\": \"Manual verification successful\",\n    \"version\": 2\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/admin/verifications/{{record_id}}/decision",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"verifications",
								"{{record_id}}",
								"decision"
							]
						}
					},
					"response": []
