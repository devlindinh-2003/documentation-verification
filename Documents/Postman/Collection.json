						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/admin/verifications?status=inconclusive&limit=20&offset=0",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"admin",
								"verifications"
							],
							"query": [
								{
									"key": "status",
