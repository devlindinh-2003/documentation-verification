# ========================
# ENVIRONMENT & SECRETS
# ========================
.env
.env.local
.env.production
.env.development
.env.test
.env.*.local

# But DO NOT ignore example files
!.env.example
!apps/backend/.env.example
!apps/frontend/.env.example

# ==============================================================================
# NODE MODULES
# ==============================================================================
node_modules/

# ==============================================================================
# BUILD OUTPUTS
# ==============================================================================
# Backend build artifacts
dist/
build/
# Frontend (Next.js) artifacts
.next/
out/

# ==============================================================================
# LOG FILES
# ==============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==============================================================================
# OS FILES
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==============================================================================
# IDE / EDITOR FILES
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
.project
.classpath
.settings/

# ==============================================================================
# TEST / COVERAGE
# ==============================================================================
coverage/
.nyc_output/

# ==============================================================================
# CACHE & TEMP
# ==============================================================================
.cache/
.tmp/
.temp/
.eslintcache

# ==============================================================================
# MISC
# ==============================================================================
# Do NOT ignore package-lock.json or yarn.lock unless explicitly required
# package-lock.json
# yarn.lock

# Ignore local database or mock storage if applicable
*.db
*.sqlite
# Local maintenance scripts
apps/backend/src/scripts/
