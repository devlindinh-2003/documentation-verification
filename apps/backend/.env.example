# ========================
# APP CONFIG
# ========================
PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:5001
CALLBACK_URL=http://localhost:8000/documents/callback

# ========================
# DATABASE
# ========================
DATABASE_URL=postgresql://postgres:user@localhost:5433/document_verification_db

# ========================
# REDIS (BullMQ)
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================
# AUTH
# ========================
JWT_SECRET=your-secret-key

# ========================
# WEBHOOK & EXTERNAL SERVICES
# ========================
HMAC_SECRET=your-hmac-secret
MOCK_VENDOR_URL=http://localhost:8000/verify

# ========================
# SUPABASE STORAGE
# ========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_BUCKET=document
